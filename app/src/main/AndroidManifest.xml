<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <queries>
        <intent>
            <action android:name="com.google.android.gms.auth.GOOGLE_SIGN_IN" />
        </intent>
    </queries>

    <application
        android:name=".PortfolioApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SwaniesPortfolio">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.App.Starting"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🚀 THE SOVEREIGN RECOVERY: Restore process consistency for widget functionality -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:launchMode="standard"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.SwaniesPortfolio">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>



        <!-- SYMMETRY FIX: Pointing to the correct Glance Receiver package -->
        <receiver
            android:name=".widget.PortfolioWidgetReceiver"
            android:exported="true"
            android:label="Swanie Portfolio Pulse">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/portfolio_widget_info" />
        </receiver>

    </application>

</manifest>