<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher + fingerprint. Bitmap: swan_asset_launcher.png (copy of your transparent PNG;
  edit/replace only this file for launcher framing). TUNE: all four insets equal — bigger = smaller swan.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <inset
            android:drawable="@drawable/swan_asset_launcher"
            android:insetLeft="18dp"
            android:insetTop="18dp"
            android:insetRight="18dp"
            android:insetBottom="18dp" />
    </item>
</layer-list>
