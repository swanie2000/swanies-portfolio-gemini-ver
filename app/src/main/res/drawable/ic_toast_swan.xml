<?xml version="1.0" encoding="utf-8"?>
<!--
  Toast chip only. Bitmap: swan_asset_toast.png — own copy so toast padding ≠ launcher.
  Toast-only bitmap with insets; CustomToast rasterizes larger then displays small for clarity.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/launcher_navy" />
        </shape>
    </item>
    <item>
        <inset
            android:drawable="@drawable/swan_asset_toast"
            android:insetLeft="18dp"
            android:insetTop="18dp"
            android:insetRight="18dp"
            android:insetBottom="18dp" />
    </item>
</layer-list>
